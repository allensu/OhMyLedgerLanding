---
import { getLangFromUrl, useTranslations, withBase } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="border-t border-ink-300/40 bg-white py-12">
  <div class="mx-auto max-w-6xl px-5">
    <div class="grid grid-cols-1 gap-10 md:grid-cols-3">
      <div>
        <div class="mb-3 flex items-center gap-2">
          <img
            src={withBase('app-icon.png')}
            alt={t('brand.name')}
            class="h-9 w-9 rounded-xl"
          />
          <span class="text-base font-bold tracking-tight">{t('brand.name')}</span>
        </div>
        <p class="text-sm text-ink-500">{t('footer.tagline')}</p>
        <p class="mt-1 text-xs text-ink-500">{t('footer.madeBy')}</p>
      </div>

      <div>
        <h3 class="mb-3 text-sm font-semibold text-ink-900">
          {t('footer.contact')}
        </h3>
        <a
          href="#"
          class="inline-flex items-center gap-2 text-sm text-ink-700 transition hover:text-brand-600"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
          {t('footer.contact.fb')}
        </a>
      </div>

      <div class="md:text-right">
        <p class="text-xs text-ink-500">{t('footer.copyright')}</p>
      </div>
    </div>
  </div>
</footer>
