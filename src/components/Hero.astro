---
import { getLangFromUrl, useTranslations, withBase } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const headlineLines = t('hero.headline').split('\n');
const subheadLines = t('hero.subhead').split('\n');
---

<section class="hero-gradient pb-20 pt-10 md:pb-28 md:pt-16">
  <div class="mx-auto grid max-w-6xl grid-cols-1 gap-12 px-5 md:grid-cols-2 md:gap-8">
    <div class="flex flex-col justify-center">
      <span
        class="mb-5 inline-flex w-fit items-center gap-2 rounded-full border border-brand-500/20 bg-brand-50 px-3 py-1 text-xs font-medium text-brand-700"
      >
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-brand-500"></span>
        {t('hero.badge')}
      </span>
      <h1 class="text-4xl font-bold leading-tight tracking-tight text-ink-900 md:text-5xl">
        {headlineLines.map((line, i) => (
          <>
            {line}
            {i < headlineLines.length - 1 && <br />}
          </>
        ))}
      </h1>
      <p class="mt-6 whitespace-pre-line text-lg text-ink-700 md:text-xl">
        {subheadLines.join('\n')}
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a
          href="https://github.com/allensu/OhMyLedgerLanding/releases/latest/download/ohmyledger.apk"
          download
          class="inline-flex items-center gap-3 rounded-2xl border-2 border-ink-900 bg-white px-5 py-2.5 text-ink-900 transition hover:bg-ink-300/10"
          aria-label={`${t('hero.cta.getitfor')} Android`}
        >
          <svg class="h-8 w-8 shrink-0 text-[#3DDC84]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M16.61 15.15c-.46 0-.84-.37-.84-.83a.84.84 0 0 1 .84-.83c.46 0 .83.37.83.83a.83.83 0 0 1-.83.83m-9.22 0a.84.84 0 0 1-.84-.83c0-.46.37-.83.84-.83.46 0 .83.37.83.83 0 .46-.37.83-.83.83m9.51-5.39 1.66-2.88a.345.345 0 0 0-.13-.47.353.353 0 0 0-.47.13l-1.69 2.92C14.96 8.78 13.5 8.5 12 8.5s-2.96.28-4.27.96L6.04 6.54a.345.345 0 0 0-.47-.13.345.345 0 0 0-.13.47l1.66 2.88C4.31 11.41 2.45 14.16 2.4 17.34h19.2c-.05-3.18-1.91-5.93-4.7-7.58Z"/>
          </svg>
          <div class="flex flex-col items-start leading-tight">
            <span class="text-[10px] font-medium uppercase tracking-wider text-ink-900/60">
              {t('hero.cta.getitfor')}
            </span>
            <span class="text-base font-semibold">Android</span>
          </div>
        </a>
        <a
          href="#features"
          class="inline-flex items-center gap-2 rounded-full border border-ink-300 bg-white px-6 py-3 text-sm font-semibold text-ink-900 transition hover:border-brand-500 hover:text-brand-600"
        >
          {t('hero.cta.secondary')}
        </a>
      </div>
      <p class="mt-4 text-xs text-ink-500">
        {t('hero.installNote')}
      </p>
    </div>

    <div class="flex items-center justify-center">
      <div
        class="phone-shadow relative aspect-[9/19] w-[260px] overflow-hidden rounded-[40px] border-[10px] border-ink-900 bg-white md:w-[300px]"
      >
        <img
          src={withBase('screenshots/home.jpg')}
          alt="OhMyLedger home screen"
          class="h-full w-full object-cover"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>
