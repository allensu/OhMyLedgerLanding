---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const headlineLines = t('hero.headline').split('\n');
const subheadLines = t('hero.subhead').split('\n');
---

<section class="hero-gradient pb-20 pt-10 md:pb-28 md:pt-16">
  <div class="mx-auto grid max-w-6xl grid-cols-1 gap-12 px-5 md:grid-cols-2 md:gap-8">
    <div class="flex flex-col justify-center">
      <span
        class="mb-5 inline-flex w-fit items-center gap-2 rounded-full border border-brand-500/20 bg-brand-50 px-3 py-1 text-xs font-medium text-brand-700"
      >
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-brand-500"></span>
        {t('hero.badge')}
      </span>
      <h1 class="text-4xl font-bold leading-tight tracking-tight text-ink-900 md:text-5xl">
        {headlineLines.map((line, i) => (
          <>
            {line}
            {i < headlineLines.length - 1 && <br />}
          </>
        ))}
      </h1>
      <p class="mt-6 whitespace-pre-line text-lg text-ink-700 md:text-xl">
        {subheadLines.join('\n')}
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a
          href="#download"
          class="inline-flex items-center gap-2 rounded-full bg-brand-500 px-6 py-3 text-sm font-semibold text-white shadow-card transition hover:bg-brand-600"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 3v12m0 0l-5-5m5 5l5-5M5 20h14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          {t('hero.cta.primary')}
        </a>
        <a
          href="#features"
          class="inline-flex items-center gap-2 rounded-full border border-ink-300 bg-white px-6 py-3 text-sm font-semibold text-ink-900 transition hover:border-brand-500 hover:text-brand-600"
        >
          {t('hero.cta.secondary')}
        </a>
      </div>
    </div>

    <div class="flex items-center justify-center">
      <div
        class="phone-shadow relative aspect-[9/19] w-[260px] overflow-hidden rounded-[40px] border-[10px] border-ink-900 bg-white md:w-[300px]"
      >
        <img
          src="/screenshots/home.jpg"
          alt="OhMyLedger home screen"
          class="h-full w-full object-cover"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>
