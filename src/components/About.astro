---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="about" class="py-20 md:py-28">
  <div class="mx-auto max-w-3xl px-5">
    <div class="mb-8 text-center">
      <h2 class="text-3xl font-bold tracking-tight text-ink-900 md:text-4xl">
        {t('about.title')}
      </h2>
    </div>
    <div class="rounded-2xl border border-ink-300/40 bg-white p-8 md:p-10">
      <p class="whitespace-pre-line text-base leading-loose text-ink-700 md:text-lg">
        {t('about.body')}
      </p>
    </div>
  </div>
</section>
