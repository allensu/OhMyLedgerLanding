---
import { getLangFromUrl, localizedPath } from '../i18n/utils';
import { languages, type Lang } from '../i18n/ui';

const currentLang = getLangFromUrl(Astro.url);
const flags: Record<Lang, string> = {
  'zh-TW': '🇹🇼',
  'zh-CN': '🇨🇳',
  en: '🇺🇸',
  ja: '🇯🇵',
};
---

<div class="relative">
  <details class="group">
    <summary
      class="flex cursor-pointer list-none items-center gap-1.5 rounded-full border border-ink-300/60 bg-white px-3 py-1.5 text-sm text-ink-700 hover:border-brand-500 hover:text-brand-600 [&::-webkit-details-marker]:hidden"
    >
      <span>{flags[currentLang]}</span>
      <span>{languages[currentLang]}</span>
      <svg
        class="h-3.5 w-3.5 transition-transform group-open:rotate-180"
        viewBox="0 0 12 12"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
      >
        <path d="M3 4.5L6 7.5L9 4.5" stroke-linecap="round" />
      </svg>
    </summary>
    <ul
      class="absolute right-0 mt-2 min-w-[160px] rounded-xl border border-ink-300/60 bg-white py-1 shadow-lg"
    >
      {
        (Object.keys(languages) as Lang[]).map((code) => (
          <li>
            <a
              href={localizedPath(code)}
              class:list={[
                'flex items-center gap-2 px-3 py-2 text-sm',
                code === currentLang
                  ? 'bg-brand-50 text-brand-600'
                  : 'text-ink-700 hover:bg-ink-300/10',
              ]}
            >
              <span>{flags[code]}</span>
              <span>{languages[code]}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </details>
</div>
