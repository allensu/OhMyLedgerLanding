---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const items = [
  {
    emoji: '⚡️',
    bg: 'bg-[#FFF3E0]',
    title: t('features.one.title'),
    body: t('features.one.body'),
  },
  {
    emoji: '🔒',
    bg: 'bg-[#E8F5E9]',
    title: t('features.two.title'),
    body: t('features.two.body'),
  },
  {
    emoji: '🌏',
    bg: 'bg-[#E3F2FD]',
    title: t('features.three.title'),
    body: t('features.three.body'),
  },
];
---

<section id="features" class="py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-5">
    <div class="mb-12 text-center">
      <h2 class="text-3xl font-bold tracking-tight text-ink-900 md:text-4xl">
        {t('features.title')}
      </h2>
      <p class="mt-3 text-base text-ink-500 md:text-lg">
        {t('features.subtitle')}
      </p>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {
        items.map((item) => (
          <div class="rounded-2xl border border-ink-300/40 bg-white p-7 transition hover:border-brand-500/50 hover:shadow-card">
            <div class={`mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl text-2xl ${item.bg}`}>
              {item.emoji}
            </div>
            <h3 class="mb-2 text-lg font-bold text-ink-900">
              {item.title}
            </h3>
            <p class="text-sm leading-relaxed text-ink-700">
              {item.body}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
