---
import '../styles/global.css';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import LangSwitcher from '../components/LangSwitcher.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/app-icon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{t('meta.title')}</title>
    <meta name="description" content={t('meta.description')} />
    <meta property="og:title" content={t('meta.title')} />
    <meta property="og:description" content={t('meta.description')} />
    <meta property="og:type" content="website" />
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;600;700&family=Noto+Sans+SC:wght@400;600;700&family=Noto+Sans+TC:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="font-sans">
    <header class="sticky top-0 z-50 border-b border-ink-300/40 bg-white/80 backdrop-blur">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-3">
        <a href={lang === 'zh-TW' ? '/' : `/${lang}/`} class="flex items-center gap-2">
          <img
            src="/app-icon.png"
            alt={t('brand.name')}
            class="h-9 w-9 rounded-xl"
          />
          <span class="text-base font-bold tracking-tight">{t('brand.name')}</span>
        </a>
        <nav class="hidden items-center gap-6 md:flex">
          <a href="#features" class="text-sm text-ink-700 hover:text-ink-900">
            {t('nav.features')}
          </a>
          <a href="#about" class="text-sm text-ink-700 hover:text-ink-900">
            {t('nav.about')}
          </a>
          <a href="#faq" class="text-sm text-ink-700 hover:text-ink-900">
            {t('nav.faq')}
          </a>
          <LangSwitcher />
        </nav>
        <div class="md:hidden">
          <LangSwitcher />
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>
  </body>
</html>
